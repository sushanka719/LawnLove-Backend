// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id
  name                   String
  username               String?
  displayUsername        String?
  email                  String
  emailVerified          Boolean   @default(false)
  image                  String?
  phoneNumber            String?
  stripeCustomerId       String?
  // better-auth `admin` plugin fields — the plugin reads/writes all of these,
  // so they must exist even though we only actively use `role`.
  role                   String    @default("user")
  banned                 Boolean   @default(false)
  banReason              String?
  banExpires             DateTime?
  // Stripe Connect (Express) — set once an agent onboards for payouts.
  stripeConnectAccountId String?
  payoutsEnabled         Boolean   @default(false)
  // Notification preferences (dashboard Settings). Email reminders default on
  // and are the only channel actually wired today; SMS "on the way" alerts are
  // a future feature (persisted but surfaced disabled in the UI); promotional
  // emails default on per product.
  emailReminders         Boolean   @default(true)
  smsOnTheWayAlerts      Boolean   @default(false)
  promotionalEmails      Boolean   @default(true)
  // Soft delete: when the customer requests account deletion we record the
  // request time and a scheduled hard-delete time (a grace period later). The
  // account stays fully usable in the meantime — the user can sign back in and
  // cancel — and a daily cron permanently removes accounts past their scheduled
  // time. `null`/`null` means the account is not scheduled for deletion.
  deletionRequestedAt    DateTime?
  deletionScheduledAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  sessions               Session[]
  accounts               Account[]
  bookings               Booking[]
  jobs                   Job[]          @relation("AgentJobs")
  savedAddresses         SavedAddress[]
  // Employees the agent manages (single-agent MVP). No login — see Employee.
  employees              Employee[]     @relation("AgentEmployees")
  // Service catalog the agent offers. Display/marketing catalog only — customer
  // bookings are driven by Plans, not these rows.
  services               Service[]      @relation("AgentServices")

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Required by the better-auth `admin` plugin (impersonation support).
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// A property a customer keeps on file for faster booking. Mirrors the address
// fields embedded on Booking (single free-text line + optional Mapbox coords).
// Exactly one row per user is the default (enforced in AddressesService, which
// unsets the others in a transaction whenever a default is set).
model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_address")
}

enum BookingFrequency {
  weekly
  biweekly
  monthly
  oneTime
}

enum BookingTimeSlot {
  morning
  midday
  afternoon
  evening
}

enum BookingStatus {
  pendingPayment
  active
  pastDue
  cancelled
  completed
}

model Booking {
  id                    String           @id @default(cuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan             @relation(fields: [planId], references: [id])
  phone                 String
  address               String
  lat                   Float?
  lng                   Float?
  boundary              Json
  areaSqFt              Int
  estimatedAreaSqFt     Int
  // Authoritative new-model amounts (CENTS). basePrice snapshots plan.basePrice
  // at booking time; areaSurcharge is the matching PlanAreaTier surcharge. The
  // amount charged to Stripe = basePrice + areaSurcharge.
  basePrice             Int
  areaSurcharge         Int
  // Legacy display columns (WHOLE DOLLARS), backfilled from the plan on create so
  // existing admin/agent/dashboard views keep rendering unchanged. `frequency`
  // is derived from the plan (interval, or oneTime). To be dropped once those
  // views read the cents fields.
  frequency             BookingFrequency
  subtotal              Int
  discountPct           Float
  totalPerVisit         Int
  scheduleDate          DateTime
  timeSlot              BookingTimeSlot
  stripeCustomerId      String
  // Legacy escrow saved-card id — null for prepaid bookings. Removed with the
  // payment-methods module in a later phase.
  stripePaymentMethodId String?
  stripeSubscriptionId  String?
  stripePaymentIntentId String?
  amountCharged         Int? // cents actually charged (set by the Stripe webhook)
  // Applied promo code (optional). discountAmount is the CENTS taken off the
  // per-visit charge (basePrice + areaSurcharge − discountAmount), recomputed
  // server-side at booking time; never trust a client-sent discount.
  promoCodeId           String?
  promoCode             PromoCode?       @relation(fields: [promoCodeId], references: [id])
  discountAmount        Int              @default(0)
  status                BookingStatus    @default(pendingPayment)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  jobs                  Job[]

  @@index([userId])
  @@index([planId])
  @@index([stripeSubscriptionId])
  @@index([promoCodeId])
  @@map("booking")
}

enum JobStatus {
  assigned
  started
  completed
  in_review
  released
  paid
  disputed
  refunded
}

enum PhotoType {
  before
  after
}

// A Job is one service visit under a Booking. One-time bookings get a single
// Job; recurring bookings get one Job per visit. Visit #1 is created at booking
// time; subsequent visits are generated by the scheduler's rolling cron window.
model Job {
  id                    String     @id @default(cuid())
  bookingId             String
  booking               Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agentId               String?
  agent                 User?      @relation("AgentJobs", fields: [agentId], references: [id])
  // The visit date (date-level; the time-of-day preference lives on booking.timeSlot).
  scheduledDate         DateTime?
  // The employee actually doing the work (null = Unassigned, retried by cron).
  employeeId            String?
  employee              Employee?  @relation(fields: [employeeId], references: [id])
  // 1,2,3… within the booking — for display and idempotent generation/dedupe.
  visitNumber           Int        @default(1)
  status                JobStatus  @default(assigned)
  startedAt             DateTime?
  completedAt           DateTime?
  startLat              Float?
  startLng              Float?
  reviewDeadline        DateTime?
  // Escrow money fields (cents). Set when the customer is charged at completion.
  amount                Int?
  platformFee           Int?
  stripePaymentIntentId String?
  stripeTransferId      String?
  chargedAt             DateTime?
  releasedAt            DateTime?
  // Deferred per-visit agent payout: amount owed is recorded at completion; the
  // disbursement mechanism (and agentPaidAt/agentPayoutRef) is wired later.
  agentPayoutAmount     Int? // cents owed to the agent for this visit
  agentPaidAt           DateTime?
  agentPayoutRef        String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  photos                JobPhoto[]
  review                Review?

  @@unique([bookingId, visitNumber])       // idempotency: never create the same visit twice
  @@index([bookingId])
  @@index([agentId])
  @@index([status])
  @@index([employeeId, scheduledDate])     // "who's busy that day" capacity query
  @@index([scheduledDate])                 // cron window scan
  @@map("job")
}

// An agent's field worker. They do NOT log in — the agent manages them as cards
// in the dashboard's Employees menu. Belongs to one agent (single-agent MVP).
model Employee {
  id        String   @id @default(cuid())
  agentId   String
  agent     User     @relation("AgentEmployees", fields: [agentId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  dailyCap  Int      @default(5) // max jobs/day — the only capacity constraint for MVP
  active    Boolean  @default(true)
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@map("employee")
}

model JobPhoto {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type       PhotoType
  storageKey String
  lat        Float?
  lng        Float?
  takenAt    DateTime
  createdAt  DateTime  @default(now())

  @@index([jobId])
  @@map("job_photo")
}

model Review {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("review")
}

enum PlanBillingType {
  recurring
  oneTime
}

// Only meaningful when billingType = recurring; null for one-time plans.
enum PlanInterval {
  weekly
  biweekly
  monthly
}

// Admin-managed booking plan. Replaces the previously hardcoded frequency tiers
// on the booking flow (fetched dynamically by /booking/schedule). The final
// per-visit charge = basePrice + the surcharge of the global AreaTier bracket
// the measured estimatedAreaSqFt falls into (see PricingConfig).
model Plan {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  billingType     PlanBillingType
  interval        PlanInterval? // required iff billingType = recurring
  basePrice       Int // cents
  features        String[] // bullet points shown on the plan card
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  stripeProductId String? // optional Stripe Product mirror for clean reporting
  bookings        Booking[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("plan")
}

// Single global pricing configuration shared by every plan. Enforced as a
// singleton via the fixed id "singleton" (always read/upserted on that id).
// Holds the shared area-surcharge ladder and the maximum serviceable area.
model PricingConfig {
  id           String     @id @default("singleton")
  maxAreaSqFt  Int? // null = no maximum serviceable area (do not block oversized lawns)
  areaTiers    AreaTier[]
  updatedAt    DateTime   @updatedAt

  @@map("pricing_config")
}

// Non-overlapping, ascending area brackets shared across all plans. The
// surcharge of the bracket the measured area falls into is added to a plan's
// basePrice (0 if the area is below the first tier's minSqFt).
model AreaTier {
  id        String        @id @default(cuid())
  configId  String
  config    PricingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  minSqFt   Int
  maxSqFt   Int? // null = no upper bound (top tier)
  surcharge Int // cents added to basePrice for this bracket

  @@index([configId])
  @@map("area_tier")
}

// An agent's offered-services catalog, managed from the agent dashboard's
// "Service" screen. This is a display/marketing catalog only — actual customer
// bookings run through Plans + PricingConfig, not these rows. Belongs to one
// agent (single-agent MVP, mirrors Employee).
model Service {
  id          String   @id @default(cuid())
  agentId     String
  agent       User     @relation("AgentServices", fields: [agentId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Int // cents
  unit        String   @default("per visit") // e.g. "per visit", "per sq ft"
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@map("service")
}

// Single global platform settings, enforced as a singleton via the fixed id
// "singleton" (mirrors PricingConfig). Backs the admin Settings screen. When
// set, platformFeePct overrides the PLATFORM_FEE_PCT env default at read time.
model AppSettings {
  id             String   @id @default("singleton")
  platformName   String   @default("LawnLove")
  supportEmail   String?
  // Commission the platform keeps on each visit (0..1). Overrides env when read.
  platformFeePct Float    @default(0.2)
  // Master switch for agent payouts (the deferred manual-payout flow honors it).
  payoutsEnabled Boolean  @default(false)
  // Informational for the MVP (payouts are admin-initiated): manual|daily|weekly.
  payoutSchedule String   @default("manual")
  updatedAt      DateTime @updatedAt

  @@map("app_settings")
}

enum PromoType {
  percent // `value` is a 1..100 percentage off the per-visit subtotal
  fixed //   `value` is a flat CENTS amount off the per-visit subtotal
}

// A discount code applied at checkout. The discount is recomputed server-side on
// POST /bookings (never trust a client-sent amount) and snapshotted onto the
// Booking as discountAmount (cents). redemptions is incremented when a booking
// successfully uses the code.
model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique // stored uppercase; matched case-insensitively
  description    String?
  type           PromoType
  value          Int // percent (1..100) or cents off, per `type`
  active         Boolean   @default(true)
  maxRedemptions Int? // null = unlimited
  redemptions    Int       @default(0)
  minSubtotal    Int? // cents; the per-visit subtotal must reach this to qualify
  expiresAt      DateTime? // null = never expires
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  bookings       Booking[]

  @@map("promo_code")
}
