// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id
  name                   String
  username               String?
  displayUsername        String?
  email                  String
  emailVerified          Boolean   @default(false)
  image                  String?
  phoneNumber            String?
  stripeCustomerId       String?
  // better-auth `admin` plugin fields — the plugin reads/writes all of these,
  // so they must exist even though we only actively use `role`.
  role                   String    @default("user")
  banned                 Boolean   @default(false)
  banReason              String?
  banExpires             DateTime?
  // Stripe Connect (Express) — set once an agent onboards for payouts.
  stripeConnectAccountId String?
  payoutsEnabled         Boolean   @default(false)
  // Notification preferences (dashboard Settings). Email reminders default on
  // and are the only channel actually wired today; SMS "on the way" alerts are
  // a future feature (persisted but surfaced disabled in the UI); promotional
  // emails default on per product.
  emailReminders         Boolean   @default(true)
  smsOnTheWayAlerts      Boolean   @default(false)
  promotionalEmails      Boolean   @default(true)
  // Soft delete: when the customer requests account deletion we record the
  // request time and a scheduled hard-delete time (a grace period later). The
  // account stays fully usable in the meantime — the user can sign back in and
  // cancel — and a daily cron permanently removes accounts past their scheduled
  // time. `null`/`null` means the account is not scheduled for deletion.
  deletionRequestedAt    DateTime?
  deletionScheduledAt    DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  sessions               Session[]
  accounts               Account[]
  bookings               Booking[]
  jobs                   Job[]     @relation("AgentJobs")

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Required by the better-auth `admin` plugin (impersonation support).
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum BookingFrequency {
  weekly
  biweekly
  monthly
  oneTime
}

enum BookingTimeSlot {
  morning
  midday
  afternoon
  evening
}

enum BookingStatus {
  pendingPayment
  active
  pastDue
  cancelled
  completed
}

model Booking {
  id                    String           @id @default(cuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan             @relation(fields: [planId], references: [id])
  phone                 String
  address               String
  lat                   Float?
  lng                   Float?
  boundary              Json
  areaSqFt              Int
  estimatedAreaSqFt     Int
  // Authoritative new-model amounts (CENTS). basePrice snapshots plan.basePrice
  // at booking time; areaSurcharge is the matching PlanAreaTier surcharge. The
  // amount charged to Stripe = basePrice + areaSurcharge.
  basePrice             Int
  areaSurcharge         Int
  // Legacy display columns (WHOLE DOLLARS), backfilled from the plan on create so
  // existing admin/agent/dashboard views keep rendering unchanged. `frequency`
  // is derived from the plan (interval, or oneTime). To be dropped once those
  // views read the cents fields.
  frequency             BookingFrequency
  subtotal              Int
  discountPct           Float
  totalPerVisit         Int
  scheduleDate          DateTime
  timeSlot              BookingTimeSlot
  stripeCustomerId      String
  // Legacy escrow saved-card id — null for prepaid bookings. Removed with the
  // payment-methods module in a later phase.
  stripePaymentMethodId String?
  stripeSubscriptionId  String?
  stripePaymentIntentId String?
  amountCharged         Int? // cents actually charged (set by the Stripe webhook)
  status                BookingStatus    @default(pendingPayment)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  jobs                  Job[]

  @@index([userId])
  @@index([planId])
  @@index([stripeSubscriptionId])
  @@map("booking")
}

enum JobStatus {
  assigned
  started
  completed
  in_review
  released
  paid
  disputed
  refunded
}

enum PhotoType {
  before
  after
}

// A Job is one service visit under a Booking. One-time bookings get a single
// Job; recurring bookings get one Job per visit (auto-generation of future
// visits is out of scope — the first Job is created at booking time).
model Job {
  id                    String     @id @default(cuid())
  bookingId             String
  booking               Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agentId               String?
  agent                 User?      @relation("AgentJobs", fields: [agentId], references: [id])
  status                JobStatus  @default(assigned)
  startedAt             DateTime?
  completedAt           DateTime?
  startLat              Float?
  startLng              Float?
  reviewDeadline        DateTime?
  // Escrow money fields (cents). Set when the customer is charged at completion.
  amount                Int?
  platformFee           Int?
  stripePaymentIntentId String?
  stripeTransferId      String?
  chargedAt             DateTime?
  releasedAt            DateTime?
  // Deferred per-visit agent payout: amount owed is recorded at completion; the
  // disbursement mechanism (and agentPaidAt/agentPayoutRef) is wired later.
  agentPayoutAmount     Int? // cents owed to the agent for this visit
  agentPaidAt           DateTime?
  agentPayoutRef        String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  photos                JobPhoto[]
  review                Review?

  @@index([bookingId])
  @@index([agentId])
  @@index([status])
  @@map("job")
}

model JobPhoto {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type       PhotoType
  storageKey String
  lat        Float?
  lng        Float?
  takenAt    DateTime
  createdAt  DateTime  @default(now())

  @@index([jobId])
  @@map("job_photo")
}

model Review {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("review")
}

enum PlanBillingType {
  recurring
  oneTime
}

// Only meaningful when billingType = recurring; null for one-time plans.
enum PlanInterval {
  weekly
  biweekly
  monthly
}

// Admin-managed booking plan. Replaces the previously hardcoded frequency tiers
// on the booking flow (fetched dynamically by /booking/schedule). The final
// per-visit charge = basePrice + the surcharge of the PlanAreaTier bracket the
// measured estimatedAreaSqFt falls into.
model Plan {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  billingType     PlanBillingType
  interval        PlanInterval? // required iff billingType = recurring
  basePrice       Int // cents
  features        String[] // bullet points shown on the plan card
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  stripeProductId String? // optional Stripe Product mirror for clean reporting
  areaTiers       PlanAreaTier[]
  bookings        Booking[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("plan")
}

// Non-overlapping, ascending area brackets for a plan. The surcharge of the
// bracket the measured area falls into is added to the plan's basePrice
// (0 if the area is below the first tier's minSqFt).
model PlanAreaTier {
  id        String @id @default(cuid())
  planId    String
  plan      Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  minSqFt   Int
  maxSqFt   Int? // null = no upper bound (top tier)
  surcharge Int // cents added to basePrice for this bracket

  @@index([planId])
  @@map("plan_area_tier")
}
