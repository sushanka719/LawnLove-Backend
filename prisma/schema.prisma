// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id
  name                   String
  username               String?
  displayUsername        String?
  email                  String
  emailVerified          Boolean   @default(false)
  image                  String?
  phoneNumber            String?
  stripeCustomerId       String?
  // better-auth `admin` plugin fields — the plugin reads/writes all of these,
  // so they must exist even though we only actively use `role`.
  role                   String    @default("user")
  banned                 Boolean   @default(false)
  banReason              String?
  banExpires             DateTime?
  // Stripe Connect (Express) — set once an agent onboards for payouts.
  stripeConnectAccountId String?
  payoutsEnabled         Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  sessions               Session[]
  accounts               Account[]
  bookings               Booking[]
  jobs                   Job[]          @relation("AgentJobs")
  savedAddresses         SavedAddress[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Required by the better-auth `admin` plugin (impersonation support).
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// A property a customer keeps on file for faster booking. Mirrors the address
// fields embedded on Booking (single free-text line + optional Mapbox coords).
// Exactly one row per user is the default (enforced in AddressesService, which
// unsets the others in a transaction whenever a default is set).
model SavedAddress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("saved_address")
}

enum BookingFrequency {
  weekly
  biweekly
  monthly
  oneTime
}

enum BookingTimeSlot {
  morning
  midday
  afternoon
  evening
}

enum BookingStatus {
  scheduled
  cancelled
  completed
}

model Booking {
  id                    String           @id @default(cuid())
  userId                String
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone                 String
  address               String
  lat                   Float?
  lng                   Float?
  boundary              Json
  areaSqFt              Int
  estimatedAreaSqFt     Int
  frequency             BookingFrequency
  subtotal              Int
  discountPct           Float
  totalPerVisit         Int
  scheduleDate          DateTime
  timeSlot              BookingTimeSlot
  stripeCustomerId      String
  stripePaymentMethodId String
  status                BookingStatus    @default(scheduled)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  jobs                  Job[]

  @@index([userId])
  @@map("booking")
}

enum JobStatus {
  assigned
  started
  completed
  in_review
  released
  paid
  disputed
  refunded
}

enum PhotoType {
  before
  after
}

// A Job is one service visit under a Booking. One-time bookings get a single
// Job; recurring bookings get one Job per visit (auto-generation of future
// visits is out of scope — the first Job is created at booking time).
model Job {
  id                    String     @id @default(cuid())
  bookingId             String
  booking               Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  agentId               String?
  agent                 User?      @relation("AgentJobs", fields: [agentId], references: [id])
  status                JobStatus  @default(assigned)
  startedAt             DateTime?
  completedAt           DateTime?
  startLat              Float?
  startLng              Float?
  reviewDeadline        DateTime?
  // Escrow money fields (cents). Set when the customer is charged at completion.
  amount                Int?
  platformFee           Int?
  stripePaymentIntentId String?
  stripeTransferId      String?
  chargedAt             DateTime?
  releasedAt            DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  photos                JobPhoto[]
  review                Review?

  @@index([bookingId])
  @@index([agentId])
  @@index([status])
  @@map("job")
}

model JobPhoto {
  id         String    @id @default(cuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type       PhotoType
  storageKey String
  lat        Float?
  lng        Float?
  takenAt    DateTime
  createdAt  DateTime  @default(now())

  @@index([jobId])
  @@map("job_photo")
}

model Review {
  id        String   @id @default(cuid())
  jobId     String   @unique
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@map("review")
}
