NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lawn

BETTER_AUTH_SECRET=replace-with-a-random-32-char-secret
BETTER_AUTH_URL=http://localhost:4000

# Comma-separated allowed origins, or omit to allow all in development
CORS_ORIGIN=http://localhost:3000

# Shared parent domain for the session cookie, with a leading dot. Set this ONLY
# when the frontend and backend are sibling subdomains of one parent, so the
# cookie is visible to both (required for the Next.js proxy.ts SSR session check).
# e.g. frontend staging.lawnlove.gettola.app + backend staging.backend.lawnlove.gettola.app
# => COOKIE_DOMAIN=.lawnlove.gettola.app
# Leave UNSET for localhost dev and for cross-registrable-domain deploys (e.g. Vercel frontend).
# COOKIE_DOMAIN=

# Sentry error monitoring — leave unset to disable
SENTRY_DSN=

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Resend — used to send magic link and password reset emails
RESEND_API_KEY=
# Optional — defaults to Resend's sandbox sender if unset. Must be on a
# domain verified in Resend (SPF/DKIM), e.g.:
MAIL_FROM="LawnHate <noreply@mail.yberry.app>"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — secret key + webhook signing secret. In dev, get the webhook secret
# from `stripe listen --forward-to localhost:4000/stripe/webhook`.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudflare R2 (S3-compatible) — job photos and profile avatars
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket (R2.dev public URL or custom domain), used to
# serve profile avatars. Required for profile photo uploads to work.
R2_PUBLIC_URL=
